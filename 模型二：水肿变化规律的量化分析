MAX_FOLLOWUP_DAYS = 14


def build_edema_timeseries(volume_df, time_df, clinical_df, target_ids, dataset_name):
    """构建水肿时间序列"""
    edema_records = []

    if len(target_ids) == 0:
        print(f"\n{dataset_name}处理: 无目标患者")
        return pd.DataFrame(edema_records)

    print(f"\n{dataset_name}处理:")
    print(f"  目标患者数: {len(target_ids)}")

    ed_cols = [c for c in volume_df.columns if 'ED_volume' in str(c)]
    hm_cols = [c for c in volume_df.columns if 'HM_volume' in str(c)]
    flow_cols = [c for c in volume_df.columns if '流水号' in str(c)]

    valid_patient_count = 0
    excluded_by_time = 0

    for idx, row in volume_df.iterrows():
        patient_id = row['ID']

        if patient_id not in target_ids:
            continue

        clinical_info = clinical_df[clinical_df['ID'] == patient_id]
        if len(clinical_info) == 0:
            continue
        clinical_info = clinical_info.iloc[0]

        time_info = time_df[time_df['ID'] == patient_id]
        if len(time_info) == 0:
            first_flow = row.get('首次检查流水号')
            if first_flow is not None and not pd.isna(first_flow):
                time_info = time_df[time_df['入院首次检查流水号'] == first_flow]
        if len(time_info) == 0:
            continue

        time_info = time_info.iloc[0]
        valid_patient_count += 1

        # 首次检查
        if len(ed_cols) > 0:
            ed_vol = row.get(ed_cols[0])
            hm_vol = row.get(hm_cols[0]) if len(hm_cols) > 0 else 0
            flow_no = row.get(flow_cols[0]) if len(flow_cols) > 0 else None

            if ed_vol is not None and not pd.isna(ed_vol) and ed_vol > 0:
                edema_records.append({
                    'ID': patient_id,
                    '数据集': dataset_name,
                    '时间点': 0,
                    '时间间隔_小时': 0.0,
                    '水肿体积': ed_vol,
                    '血肿体积': hm_vol if hm_vol is not None and not pd.isna(hm_vol) else 0,
                    '检查流水号': flow_no,
                    '年龄': clinical_info.get('年龄'),
                    '性别': clinical_info.get('性别'),
                    '高血压病史': clinical_info.get('高血压病史'),
                    '脑室引流': clinical_info.get('脑室引流'),
                    '止血治疗': clinical_info.get('止血治疗'),
                    '降颅压治疗': clinical_info.get('降颅压治疗'),
                    '降压治疗': clinical_info.get('降压治疗'),
                    '镇静、镇痛治疗': clinical_info.get('镇静、镇痛治疗'),
                    '止吐护胃': clinical_info.get('止吐护胃'),
                    '营养神经': clinical_info.get('营养神经'),
                })

        # 随访1-8
        for i in range(1, min(len(ed_cols), 9)):
            ed_vol = row.get(ed_cols[i]) if i < len(ed_cols) else None
            hm_vol = row.get(hm_cols[i]) if i < len(hm_cols) else None
            flow_no = row.get(flow_cols[i]) if i < len(flow_cols) else None

            if ed_vol is None or pd.isna(ed_vol) or ed_vol <= 0:
                continue

            hours_elapsed = float(i * 24)

            time_col = f'随访{i}时间点'
            first_time_col = '入院首次检查时间点'

            if time_col in time_info.index and first_time_col in time_info.index:
                try:
                    first_time_val = time_info[first_time_col]
                    current_time_val = time_info[time_col]

                    if pd.notna(first_time_val) and pd.notna(current_time_val):
                        first_time = pd.to_datetime(first_time_val)
                        current_time = pd.to_datetime(current_time_val)
                        delta = current_time - first_time
                        hours_elapsed = delta.total_seconds() / 3600
                except:
                    hours_elapsed = float(i * 24)

            if hours_elapsed > MAX_FOLLOWUP_DAYS * 24:
                excluded_by_time += 1
                continue

            edema_records.append({
                'ID': patient_id,
                '数据集': dataset_name,
                '时间点': i,
                '时间间隔_小时': hours_elapsed,
                '水肿体积': ed_vol,
                '血肿体积': hm_vol if hm_vol is not None and not pd.isna(hm_vol) else 0,
                '检查流水号': flow_no,
                '年龄': clinical_info.get('年龄'),
                '性别': clinical_info.get('性别'),
                '高血压病史': clinical_info.get('高血压病史'),
                '脑室引流': clinical_info.get('脑室引流'),
                '止血治疗': clinical_info.get('止血治疗'),
                '降颅压治疗': clinical_info.get('降颅压治疗'),
                '降压治疗': clinical_info.get('降压治疗'),
                '镇静、镇痛治疗': clinical_info.get('镇静、镇痛治疗'),
                '止吐护胃': clinical_info.get('止吐护胃'),
                '营养神经': clinical_info.get('营养神经'),
            })

    print(f"  有效处理患者数: {valid_patient_count}")
    print(f"  因超时间范围排除记录数: {excluded_by_time}")
    return pd.DataFrame(edema_records)


