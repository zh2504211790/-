print("\n" + "=" * 80)
print("【4】K-means聚类 - 水肿演进模式识别（3-5亚组，每亚组≥5人）")
print("=" * 80)

print("\n【4.1】构建患者级别聚类特征...")

patient_features = edema_df_clean.groupby('ID').agg({
    '水肿体积': ['mean', 'max', 'min', 'std'],
    '时间间隔_小时': ['max', 'count'],
    '血肿体积': 'mean',
    '数据集': 'first'
}).reset_index()
patient_features.columns = ['ID', '平均水肿体积', '最大水肿体积', '最小水肿体积',
                            '水肿体积标准差', '最大时间间隔', '观测次数',
                            '平均血肿体积', '数据集']

patient_features['水肿体积标准差'] = patient_features['水肿体积标准差'].fillna(0)
patient_features['水肿变化率'] = (patient_features['最大水肿体积'] - patient_features['最小水肿体积']) / \
                                 (patient_features['最大时间间隔'] + 1)

first_edema = edema_df_clean[edema_df_clean['时间点'] == 0].groupby('ID')['水肿体积'].first().reset_index()
first_edema.columns = ['ID', '初始水肿体积']
patient_features = patient_features.merge(first_edema, on='ID', how='left')
patient_features['初始水肿体积'] = patient_features['初始水肿体积'].fillna(patient_features['最小水肿体积'])
patient_features['水肿峰值倍数'] = patient_features['最大水肿体积'] / (patient_features['初始水肿体积'] + 1)
patient_features['水肿增长幅度'] = patient_features['最大水肿体积'] - patient_features['初始水肿体积']

print(f"患者特征数据形状: {patient_features.shape}")
print(f"训练集患者数: {len(patient_features[patient_features['数据集'] == '训练集'])}")
print(f"测试集2患者数: {len(patient_features[patient_features['数据集'] == '测试集2'])}")

print("\n【4.2】特征标准化...")

train_features = patient_features[patient_features['数据集'] == '训练集'].copy()
test2_features = patient_features[patient_features['数据集'] == '测试集2'].copy()

feature_cols = ['平均水肿体积', '最大水肿体积', '初始水肿体积', '水肿变化率',
                '水肿峰值倍数', '水肿增长幅度']
scaler = RobustScaler()
X_train_cluster = scaler.fit_transform(train_features[feature_cols])

if len(test2_features) > 0:
    X_test2_cluster = scaler.transform(test2_features[feature_cols])
else:
    X_test2_cluster = None
    test2_features = pd.DataFrame()

print("\n【4.3】确定最佳聚类数（K=3到5，强制每亚组≥5人）...")

MIN_CLUSTER_SIZE = 5
K_range = [3, 4, 5]
cluster_results = {}

for k in K_range:
    best_valid_result = None

    # 尝试500次随机初始化
    for seed in range(500):
        kmeans = KMeans(n_clusters=k, random_state=seed, n_init=10, max_iter=500, init='k-means++')
        labels = kmeans.fit_predict(X_train_cluster)
        cluster_counts = np.bincount(labels)
        min_size = np.min(cluster_counts)

        if min_size >= MIN_CLUSTER_SIZE:
            sil_score = silhouette_score(X_train_cluster, labels)
            if best_valid_result is None or sil_score > best_valid_result['silhouette']:
                best_valid_result = {
                    'kmeans': kmeans,
                    'labels': labels,
                    'silhouette': sil_score,
                    'cluster_counts': cluster_counts,
                    'min_cluster_size': min_size,
                    'seed': seed
                }

    # 尝试GMM
    for seed in range(100):
        try:
            gmm = GaussianMixture(n_components=k, random_state=seed, n_init=5, covariance_type='full')
            labels = gmm.fit_predict(X_train_cluster)
            cluster_counts = np.bincount(labels)
            min_size = np.min(cluster_counts)

            if min_size >= MIN_CLUSTER_SIZE:
                sil_score = silhouette_score(X_train_cluster, labels)
                if best_valid_result is None or sil_score > best_valid_result['silhouette']:
                    best_valid_result = {
                        'gmm': gmm,
                        'labels': labels,
                        'silhouette': sil_score,
                        'cluster_counts': cluster_counts,
                        'min_cluster_size': min_size,
                        'seed': seed
                    }
        except:
            continue

    if best_valid_result is not None:
        cluster_results[k] = best_valid_result
        method_name = 'GMM' if 'gmm' in best_valid_result else 'K-means'
        print(f"  K={k}: ✓ 有效, 方法={method_name}, 轮廓系数={best_valid_result['silhouette']:.4f}, "
              f"分布={best_valid_result['cluster_counts'].tolist()}")
    else:
        print(f"  K={k}: ✗ 无法找到满足条件的聚类")

# 选择最佳K
print("\n【4.4】选择最佳聚类数...")

valid_options = [(k, v) for k, v in cluster_results.items()]

if len(valid_options) > 0:
    best_k = max(valid_options, key=lambda x: x[1]['silhouette'])[0]
else:
    best_k = 3
    kmeans = KMeans(n_clusters=3, random_state=42, n_init=50, max_iter=500)
    labels = kmeans.fit_predict(X_train_cluster)
    cluster_results[3] = {
        'kmeans': kmeans,
        'labels': labels,
        'silhouette': silhouette_score(X_train_cluster, labels),
        'cluster_counts': np.bincount(labels),
        'min_cluster_size': np.min(np.bincount(labels))
    }

