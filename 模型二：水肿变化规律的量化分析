    labels = best_result['labels'].copy()

    while np.min(np.bincount(labels)) < MIN_CLUSTER_SIZE:
        cluster_counts = np.bincount(labels)
        min_cluster = np.argmin(cluster_counts)
        min_cluster_indices = np.where(labels == min_cluster)[0]

        if 'kmeans' in best_result:
            centers = best_result['kmeans'].cluster_centers_
        elif 'gmm' in best_result:
            centers = best_result['gmm'].means_
        else:
            centers = np.array([X_train_cluster[labels == i].mean(axis=0) for i in range(best_k)])

        for idx in min_cluster_indices:
            distances = [np.linalg.norm(X_train_cluster[idx] - centers[i]) for i in range(best_k) if i != min_cluster]
            nearest_cluster = [i for i in range(best_k) if i != min_cluster][np.argmin(distances)]
            labels[idx] = nearest_cluster

    best_result['labels'] = labels
    best_result['cluster_counts'] = np.bincount(labels)
    best_result['min_cluster_size'] = np.min(np.bincount(labels))
    best_result['silhouette'] = silhouette_score(X_train_cluster, labels)

