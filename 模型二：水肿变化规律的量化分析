# 第四部分：全局多项式回归模型（AIC准则择优）
# ============================================================================

print("\n" + "=" * 80)
print("【3】全局水肿进展曲线 - AIC准则择优")
print("=" * 80)

print("\n【3.1】拟合多项式回归模型（线性、二次、三次）...")

X = edema_df_clean['时间间隔_小时'].values.reshape(-1, 1)
y = edema_df_clean['水肿体积'].values

models = {}
results = []

for degree in [1, 2, 3]:
    poly = PolynomialFeatures(degree=degree)
    X_poly = poly.fit_transform(X)
    model = LinearRegression()
    model.fit(X_poly, y)
    y_pred = model.predict(X_poly)
    mse = mean_squared_error(y, y_pred)
    r2 = r2_score(y, y_pred)
    n = len(y)
    k = degree + 1
    rss = np.sum((y - y_pred) ** 2)
    aic = n * np.log(rss / n) + 2 * k

    models[degree] = {'model': model, 'poly': poly, 'r2': r2, 'mse': mse, 'aic': aic, 'y_pred': y_pred}
    degree_name = {1: '线性', 2: '二次', 3: '三次'}
    results.append({'阶数': degree, '类型': degree_name[degree], 'R²': r2, 'MSE': mse, 'AIC': aic})
    print(f"  {degree_name[degree]}多项式: R²={r2:.4f}, MSE={mse:.2f}, AIC={aic:.2f}")

results_df = pd.DataFrame(results)
best_degree = results_df.loc[results_df['AIC'].idxmin(), '阶数']
best_model = models[int(best_degree)]
degree_name = {1: '线性', 2: '二次', 3: '三次'}
print(f"\n【3.2】最佳模型: {degree_name[int(best_degree)]}多项式 (AIC={best_model['aic']:.2f})")

residuals = y - best_model['y_pred']

