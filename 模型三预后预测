}
imp['中文特征'] = imp['feature'].map(feature_name_map).fillna(imp['feature'])

key_features_model1 = ['expansion_prob', 'expansion_x_subgroup']
key_features_model2 = ['亚组标签', '平均水肿体积', '水肿变化率', '初始水肿体积', '水肿峰值倍数']

plt.figure(figsize=(14, 10))
bars = plt.barh(imp['中文特征'][:15], imp['importance'][:15], color='steelblue')
for i, (f, val) in enumerate(zip(imp['feature'][:15], imp['importance'][:15])):
    if f in key_features_model1:
        bars[i].set_color('darkorange')
