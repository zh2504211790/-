plt.gca().invert_yaxis()
plt.xlabel('重要性', fontsize=12)
plt.title('特征重要性（随机森林）', fontsize=14, fontweight='bold')
plt.tight_layout()
imp_fig_path = os.path.join(base_path, "feature_importance_optimized.png")
plt.savefig(imp_fig_path, dpi=300, bbox_inches='tight')
plt.show()
print(f"特征重要性图（优化版）已保存至: {imp_fig_path}")

# ================== 13. SHAP分析（优化版） ==================
if SHAP_AVAILABLE:
    print("计算SHAP值...")
    explainer = shap.TreeExplainer(interpret_model)
    shap_values = explainer.shap_values(X_train_scaled[:100])
