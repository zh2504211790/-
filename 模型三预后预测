    shap.summary_plot(shap_values, X_train_scaled[:100], feature_names=shap_feature_names,
                      show=False, max_display=15, plot_size=(12, 8))
    plt.xlabel('SHAP值（对预测结果的贡献）', fontsize=12)
    plt.title('特征SHAP值总结\n（红色：高值使预测向不良预后方向移动；蓝色：低值使预测向良好预后方向移动）', fontsize=12, fontweight='bold')
    plt.tight_layout()
    shap_fig_path = os.path.join(base_path, "shap_summary_plot_optimized.png")
    plt.savefig(shap_fig_path, dpi=300, bbox_inches='tight')
    print(f"SHAP图（优化版）已保存至: {shap_fig_path}")
else:
    print("SHAP未安装，跳过SHAP图生成。")

