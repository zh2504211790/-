# 13.3 最佳模型（逻辑回归）的ROC曲线（训练集5折交叉验证平均ROC + 测试集2 ROC）
# 计算训练集5折交叉验证的ROC曲线
cv = StratifiedKFold(5)
tprs = []
aucs = []
mean_fpr = np.linspace(0, 1, 100)
plt.figure(figsize=(8, 6))
for i, (train_idx, val_idx) in enumerate(cv.split(X_train_sel_scaled, y)):
